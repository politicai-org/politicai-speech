# orbe-speech configuration

# Model storage (pre-downloaded in Docker image)
MODEL_PATH=/app/models

# TTS model: language-specific MMS model
TTS_LANGUAGE=quz
TTS_MODEL_NAME=facebook/mms-tts-quz
TTS_MAX_CHARS=1000

# STT model
STT_MODEL_NAME=openai/whisper-small

# Security — must match HF_SPEECH_API_KEY in orbe's config
API_KEY=speech-dev-key-2024

# CORS — allow calls from orbe microservice
CORS_ORIGINS=["http://localhost:8003","http://orbe-api:8003"]
