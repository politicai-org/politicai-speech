# orbe-speech configuration

# Model storage (pre-downloaded in Docker image)
MODEL_PATH=/app/models
HF_HOME=/app/models
TRANSFORMERS_CACHE=/app/models/hub
HUGGINGFACE_HUB_CACHE=/app/models/hub

# TTS model: language-specific MMS model
TTS_LANGUAGE=quz
TTS_MODEL_NAME=facebook/mms-tts-quz
TTS_MAX_CHARS=1000

# STT model
STT_MODEL_NAME=openai/whisper-small

# Security — must match HF_SPEECH_API_KEY in orbe's config
API_KEY=speech-dev-key-2024

# ElevenLabs TTS (optional)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# AWS Polly TTS (optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# MiniMax TTS with Voice Cloning
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_BASE_URL=https://api.minimax.chat/v1/text_to_speech

# CORS — allow calls from orbe microservice
CORS_ORIGINS=["http://localhost:8003","http://orbe-api:8003"]

# Logging
LOG_LEVEL=INFO
